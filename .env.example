# Base layer (devnet) — used by Anchor tests (test.sh / anchor test)
BASE_ENDPOINT=https://api.devnet.solana.com
BASE_WS_ENDPOINT=wss://api.devnet.solana.com

# Ephemeral rollup (devnet TEE) — must match ER_VALIDATOR for delegation + ER txs
EPHEMERAL_ENDPOINT=https://devnet-tee.magicblock.app
EPHEMERAL_WS_ENDPOINT=wss://devnet-tee.magicblock.app
ER_VALIDATOR=MTEWGuqxUpYZGFJQcp8tLN7x5v9BSeoFHYWQQ3n3xzo

# Optional Vite aliases (same values; web reads EPHEMERAL_* / ER_* from repo root .env)
# VITE_EPHEMERAL_URL=https://devnet-tee.magicblock.app
# VITE_EPHEMERAL_WS_URL=wss://devnet-tee.magicblock.app
# VITE_ER_VALIDATOR=MTEWGuqxUpYZGFJQcp8tLN7x5v9BSeoFHYWQQ3n3xzo

# Test keypairs (anchor test only — never commit real secrets)
P1B=[]
P2B=[]
